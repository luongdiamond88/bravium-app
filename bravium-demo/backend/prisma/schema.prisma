generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  INVESTOR
  ADMIN
}

enum DevicePlatform {
  WEB
  ANDROID_WRAPPER
  ROBOT
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
}

enum SessionStatus {
  OPEN
  CLOSED
}

enum AiJobType {
  REPLY
  SCAM_ALERT
  BUDGET_PARSE
  ANALYSIS
}

enum AiJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum AiOutputType {
  REPLY
  ALERT
  PARSED_EXPENSE
  ANALYSIS_SUMMARY
}

enum ApprovalStatus {
  REQUESTED
  APPROVED
  REJECTED
  EXPIRED
}

enum NotificationType {
  REMINDER
  BUDGET_ALERT
  AI_ALERT
}

enum NotificationStatus {
  PENDING
  SENT
  READ
}

enum FixedExpenseStatus {
  ACTIVE
  INACTIVE
}

model User {
  id            String         @id @default(cuid())
  email         String?        @unique
  name          String?
  role          UserRole       @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  devices       Device[]
  sessions      Session[]
  eventLogs     EventLog[]
  aiJobs        AiJob[]
  aiOutputs     AiOutput[]
  approvals     Approval[]
  notifications Notification[]
  fixedExpenses  FixedExpense[]
  communityRequests CommunityRequest[]

  @@map("users")
}

model Device {
  id          String         @id @default(cuid())
  userId      String
  deviceCode  String         @unique
  label       String?
  platform    DevicePlatform
  status      DeviceStatus   @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions    Session[]
  eventLogs   EventLog[]

  @@index([userId])
  @@index([platform, status])
  @@map("devices")
}

model Session {
  id                 String         @id @default(cuid())
  userId             String
  deviceId           String?
  frontendSessionId  String?        @unique
  status             SessionStatus  @default(OPEN)
  startedAt          DateTime       @default(now())
  endedAt            DateTime?
  metadata           Json?

  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  device             Device?        @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  eventLogs          EventLog[]
  aiJobs             AiJob[]
  approvals          Approval[]

  @@index([userId, status])
  @@index([deviceId])
  @@index([startedAt])
  @@map("sessions")
}

model EventLog {
  id             String    @id @default(cuid())
  userId         String?
  deviceId       String?
  sessionId      String?
  type           String
  source         String
  category       String?
  correlationId  String?
  payload        Json
  createdAt      DateTime  @default(now())

  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  device         Device?   @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  session        Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
  @@index([userId, createdAt])
  @@index([deviceId, createdAt])
  @@index([type, createdAt])
  @@index([category, createdAt])
  @@index([correlationId])
  @@map("event_logs")
}

model AiJob {
  id            String       @id @default(cuid())
  userId        String
  sessionId     String?
  type          AiJobType
  status        AiJobStatus  @default(QUEUED)
  input         Json
  createdAt     DateTime     @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  error         String?

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  session       Session?     @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  outputs       AiOutput[]

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([type, status])
  @@map("ai_jobs")
}

model AiOutput {
  id           String        @id @default(cuid())
  jobId        String
  userId       String
  outputType   AiOutputType
  content      Json
  createdAt    DateTime      @default(now())

  job          AiJob         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@index([userId, createdAt])
  @@index([outputType, createdAt])
  @@map("ai_outputs")
}

model Approval {
  id              String          @id @default(cuid())
  userId          String
  sessionId       String?
  actionType      String
  status          ApprovalStatus  @default(REQUESTED)
  requestPayload  Json
  decidedAt       DateTime?
  decisionReason  String?
  createdAt       DateTime        @default(now())

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  session         Session?        @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([status, createdAt])
  @@index([actionType, status])
  @@map("approvals")
}

model Notification {
  id            String              @id @default(cuid())
  userId        String
  type          NotificationType
  title         String
  body          String
  status        NotificationStatus  @default(PENDING)
  scheduledFor  DateTime?
  sentAt        DateTime?
  payload       Json?
  createdAt     DateTime            @default(now())

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type, status])
  @@index([scheduledFor])
  @@map("notifications")
}

model FixedExpense {
  id          String             @id @default(cuid())
  userId      String
  label       String
  amount      Float
  currency    String
  dueDay      Int
  recurrence  String             @default("monthly")
  sourceText  String?
  category    String?
  status      FixedExpenseStatus @default(ACTIVE)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, dueDay])
  @@map("fixed_expenses")
}

model CommunityRequest {
  id                String   @id @default(cuid())
  userId            String
  sessionId         String?
  source            String
  question          String
  caseSummary       String
  riskLevel         String
  redFlags          Json?
  recommendedAction String?
  status            String   @default("submitted")
  createdAt         DateTime @default(now())

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@map("community_requests")
}