# ------------------------------------------------------
# ⚙️ Cấu hình chạy Bravium App (React + Vite + PWA)
# ------------------------------------------------------

run = "cd bravium-demo && npm install && npm run dev -- --host"

language = "nodejs"
modules = ["nodejs-20"]

[env]
PORT = "5173"

# Giữ console mở để xem log
[interpreter]
command = ["bash", "-c"]

# Môi trường hiển thị logs rõ ràng hơn
entrypoint = "bravium-demo"

[[ports]]
localPort = 80
externalPort = 3000

[[ports]]
localPort = 4173
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 5000

[[ports]]
localPort = 5002
externalPort = 6000

[[ports]]
localPort = 5003
externalPort = 4200

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 5174
externalPort = 3001

[[ports]]
localPort = 5175
externalPort = 3002

[[ports]]
localPort = 5176
externalPort = 3003

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Server"

[[workflows.workflow]]
name = "Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd bravium-demo && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[nix]
packages = ["file"]
